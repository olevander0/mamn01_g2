<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/timer_finished_bubble"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_rectangle"
    android:orientation="vertical"
    android:padding="28dp"
    android:elevation="16dp"
    android:gravity="center"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">

    <!-- RESTART BUTTON: The primary action -->
    <Button
        android:id="@+id/btn_restart_timer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Restart"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:fontFamily="@font/rubik"
        android:textColor="@color/background"
        android:backgroundTint="@color/progress" />

    <!-- STOP BUTTON: Uses our custom outline drawable -->
    <Button
        android:id="@+id/btn_stop_timer"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:text="Stop and Close"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:fontFamily="@font/rubik"
        android:textColor="@color/text"
        android:background="@drawable/bg_outlined_button" />

</LinearLayout>