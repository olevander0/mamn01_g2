<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_timer_picker_dialog"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="20dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/infoDialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/rubik"
            android:text="@string/info_dialog_title"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/closeInfoDialogButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="@color/transparent"
            android:contentDescription="@string/close_info_dialog"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_timer_close"
            android:tint="@color/text" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/InfoDialogHeading"
                android:text="@string/info_dialog_set_time_title" />

            <TextView
                style="@style/InfoDialogBody"
                android:text="@string/info_dialog_set_time_body" />

            <TextView
                style="@style/InfoDialogHeading"
                android:text="@string/info_dialog_start_pause_title" />

            <TextView
                style="@style/InfoDialogBody"
                android:text="@string/info_dialog_start_pause_body" />

            <TextView
                style="@style/InfoDialogHeading"
                android:text="@string/info_dialog_shortcuts_title" />

            <TextView
                style="@style/InfoDialogBody"
                android:layout_marginBottom="0dp"
                android:text="@string/info_dialog_shortcuts_body" />
        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/dismissInfoDialogButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/rubik"
        android:minWidth="88dp"
        android:text="@string/info_dialog_dismiss"
        android:textAllCaps="false"
        android:textColor="@color/background"
        android:textSize="15sp"
        app:backgroundTint="@color/progress" />
</LinearLayout>
